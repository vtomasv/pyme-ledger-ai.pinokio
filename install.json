{
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<div style='padding:20px;background:#f0f4ff;border-radius:12px;margin:16px;border:1px solid #0D3DA6'><h2 style='color:#0D3DA6;margin-bottom:8px'>CCS — Pyme Ledger AI</h2><p style='color:#475569'>Instalación automática. Este proceso puede tardar 5-15 minutos la primera vez.</p><p style='color:#64748b;font-size:12px;margin-top:8px'>Plataforma: {{platform}} | RAM: {{ram}}GB | GPU: {{gpu || 'N/A'}}</p></div>"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='padding:16px'><h3 style='color:#0D3DA6'>1/4 — Verificando motor de IA (Ollama)...</h3><p style='color:#64748b'>Motor de IA local para ejecutar modelos 100% offline.</p></div>"
      }
    },

    {
      "method": "shell.run",
      "params": {
        "message": "python scripts/install_ollama.py",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='padding:16px'><h3 style='color:#0D3DA6'>2/4 — Configurando entorno Python y dependencias...</h3><p style='color:#64748b'>Creando entorno virtual e instalando librerías (OCR, PDF, servidor web).</p></div>"
      }
    },

    {
      "method": "shell.run",
      "params": {
        "message": "python setup.py",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='padding:16px'><h3 style='color:#0D3DA6'>3/4 — Descargando modelos de IA...</h3><p style='color:#64748b'>Agente de lenguaje (~500MB) y agente visual (~1.8GB). Solo se descarga una vez.</p></div>"
      }
    },

    {
      "method": "shell.run",
      "params": {
        "message": "python scripts/pull_models.py",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='padding:16px'><h3 style='color:#0D3DA6'>4/4 — Guardando configuración...</h3></div>"
      }
    },

    {
      "method": "fs.write",
      "params": {
        "path": "data/config.json",
        "text": "{{JSON.stringify({version:'1.4.0',installedAt:new Date().toISOString(),platform:platform,arch:arch,ram:ram,vram:vram,gpu:gpu,textModel:'qwen3:0.6b',visionModel:'moondream',ollamaUrl:'http://127.0.0.1:11434',ollamaTimeout:300},null,2)}}"
      }
    },

    {
      "method": "log",
      "params": {
        "html": "<div style='padding:20px;background:#ecfdf5;border-radius:8px;margin:16px;border:1px solid #3DAE2B'><h3 style='color:#3DAE2B;margin-bottom:8px'>Instalación completada</h3><p style='color:#374151'>Pyme Ledger AI está listo para usar:</p><ul style='color:#374151;margin-top:8px'><li>Motor de IA local configurado</li><li>Agentes de lenguaje y visión descargados</li><li>OCR multi-estrategia instalado</li><li>Base de datos configurada</li></ul><p style='margin-top:12px;color:#64748b'>Haz click en <strong>Iniciar</strong> para comenzar.</p></div>"
      }
    },

    {
      "method": "notify",
      "params": {
        "html": "CCS Pyme Ledger AI instalado. Haz click en Iniciar para comenzar."
      }
    }
  ]
}

{
  "run": [
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'start /B ollama serve > NUL 2>&1' : 'ollama serve > /dev/null 2>&1 &'}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "{{platform === 'win32' ? 'ping -n 3 127.0.0.1 > NUL' : 'sleep 2'}}"
      }
    },
    {
      "method": "shell.run",
      "params": {
        "message": "python launcher.py",
        "path": "{{cwd}}",
        "env": {
          "PORT": "{{port}}",
          "DATA_DIR": "{{cwd}}/data",
          "PLUGIN_DIR": "{{cwd}}",
          "OLLAMA_URL": "http://localhost:11434"
        }
      }
    }
  ]
}

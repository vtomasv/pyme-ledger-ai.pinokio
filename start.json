{
  "daemon": true,
  "run": [
    {
      "method": "log",
      "params": {
        "html": "<div style='padding:16px'><h3 style='color:#f1f5f9'>Iniciando Pyme Ledger AI...</h3></div>"
      }
    },

    {
      "method": "shell.run",
      "params": {
        "message": "python scripts/start_ollama.py",
        "path": "{{cwd}}"
      }
    },

    {
      "method": "shell.run",
      "params": {
        "message": "python launcher.py",
        "path": "{{cwd}}",
        "env": {
          "PORT": "{{port}}",
          "DATA_DIR": "{{path.resolve(cwd, 'data')}}",
          "PLUGIN_DIR": "{{cwd}}",
          "OLLAMA_URL": "http://127.0.0.1:11434"
        },
        "on": [
          {
            "event": "/Uvicorn running/",
            "done": true
          }
        ]
      }
    }
  ]
}
